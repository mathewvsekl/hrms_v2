# HRMS V2 Production .htaccess
# Avantgarde HRMS — avantgarde.glowlady.in

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Protect sensitive directories and files
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
    RewriteRule ^app/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^tmp/ - [F,L]
    RewriteRule ^\.env - [F,L]
    
    # HARD DENY: Prevent direct access to any .php file in root except index.php
    RewriteCond %{REQUEST_URI} !^/index\.php$
    RewriteCond %{REQUEST_FILENAME} \.php$
    RewriteRule ^ - [F,L]

    # Block sensitive extensions
    RewriteRule \.(sql|bak|log|sh|bat|exe|env|json|yml|yaml|xml)$ - [F,L]
</IfModule>

# Route /api/ and /public/ requests to PHP backend
RewriteCond %{REQUEST_URI} ^/api/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/public/ [NC]
RewriteRule ^(.*)$ index.php [QSA,L]

# Serve static assets directly (JS, CSS, images, fonts)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# React SPA fallback — all other routes go to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^ index.html [L]

# Enable gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets (1 year for hashed files)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>
