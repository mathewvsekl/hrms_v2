# HRMS V2 - Environment Configuration Example

# Active Environment: local, hevista, production
ACTIVE_ENVIRONMENT=local

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hrms_v2
DB_USER=root
DB_PASS=secret
DB_CHARSET=utf8mb4

# Mail Configuration
MAIL_DRIVER=mail
MAIL_FROM_ADDRESS=hrms@anedins.com
MAIL_FROM_NAME="Avantgarde HRMS"

# Mailgun Settings (Required if MAIL_DRIVER=mailgun)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_domain.com
MAILGUN_ENDPOINT=https://api.eu.mailgun.net/v3/your_domain.com/messages

# App Configuration
APP_URL=http://localhost
ENVIRONMENT=development

# Security
SESSION_SECURE=false

# Redis Configuration (Optional, fallbacks to Filesystem if empty)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASS=

# Audit Logging
AUDIT_LOG_ENABLED=true
